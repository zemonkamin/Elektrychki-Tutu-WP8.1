<Page
    x:Class="Электрички_Туту.rasp"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Электрички_Туту"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pivot for Today/Tomorrow selection with all content inside -->
        <Pivot x:Name="DatePivot" Grid.Row="0" Margin="0,0,0,0" SelectionChanged="DatePivot_SelectionChanged">
            <!-- Today's schedule -->
            <PivotItem Header="Сегодня">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Today's content with scrolling station names -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" x:Name="TodayScheduleScrollViewer">
                        <StackPanel>
                            <!-- Main stations display (will scroll with content) -->
                            <TextBlock x:Name="TodayStationsTextBlock" FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,10" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                            
                            <!-- No schedule message -->
                            <TextBlock x:Name="TodayNoScheduleTextBlock" Text="На сегодня электричек больше не было запланировано." 
                                       FontSize="18" TextAlignment="Center" Margin="20,50" Visibility="Collapsed" Foreground="Gray" TextWrapping="Wrap"/>
                            
                            <!-- Today's schedule list -->
                            <ListView x:Name="TodayScheduleListView" Margin="0" SelectionMode="Single" IsItemClickEnabled="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="15,10" Margin="0" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Vertical">
                                                <!-- Green badge for first 3 items with "Через" prefix for time values -->
                                                <Border Background="Green" CornerRadius="4" Padding="7,3" Margin="0,0,0,15" HorizontalAlignment="Left" 
                                                        Visibility="{Binding time_until_departure_visibility}">
                                                    <TextBlock FontSize="14" Foreground="White" HorizontalAlignment="Center">
                                                        <Run Text="{Binding time_until_departure_prefix}"/>
                                                        <Run Text="{Binding time_until_departure_value}"/>
                                                    </TextBlock>
                                                </Border>
                                                
                                                <!-- Main grid with three columns -->
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <!-- Row for times -->
                                                        <RowDefinition Height="Auto"/>
                                                        <!-- Row for paths -->
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- Left column: Departure time -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding departure_time}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    
                                                    <!-- Center column: Travel duration with longer gray bars -->
                                                    <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Left gray bar (1.5x longer) -->
                                                        <Rectangle Grid.Column="0" Fill="LightGray" Width="75" Height="1" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        
                                                        <!-- Centered travel duration -->
                                                        <TextBlock Grid.Column="1" Text="{Binding travel_duration}" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        
                                                        <!-- Right gray bar (1.5x longer) -->
                                                        <Rectangle Grid.Column="2" Fill="LightGray" Width="75" Height="1" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                    </Grid>
                                                    
                                                    <!-- Right column: Arrival time -->
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding arrival_time}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    
                                                    <!-- Left column: Departure path -->
                                                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Foreground="Gray" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Run Text="Путь "/>
                                                        <Run Text="{Binding path}"/>
                                                    </TextBlock>
                                                    
                                                    <!-- Right column: Arrival path -->
                                                    <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Foreground="Gray" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <Run Text="Путь "/>
                                                        <Run Text="{Binding path}"/>
                                                    </TextBlock>
                                                </Grid>
                                                
                                                <!-- Train type with color coding -->
                                                <TextBlock Text="{Binding train_type}" FontSize="14" Foreground="{Binding train_type_color}" HorizontalAlignment="Left" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding train_route}" FontSize="16" Foreground="Gray" HorizontalAlignment="Left" Margin="0,2,0,5" TextWrapping="Wrap" Visibility="{Binding train_route_visibility}"/>
                                                
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Loading indicator (white color) -->
                    <ProgressRing x:Name="TodayLoadingProgressRing" Grid.Row="0" Width="50" Height="50" IsActive="False" 
                                  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0"/>
                </Grid>
            </PivotItem>
            
            <!-- Tomorrow's schedule -->
            <PivotItem Header="Завтра">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Tomorrow's content with scrolling station names -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" x:Name="TomorrowScheduleScrollViewer">
                        <StackPanel>
                            <!-- Main stations display (will scroll with content) -->
                            <TextBlock x:Name="TomorrowStationsTextBlock" FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,10" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                            
                            <!-- No schedule message -->
                            <TextBlock x:Name="TomorrowNoScheduleTextBlock" Text="На завтра электричек не найдено." 
                                       FontSize="18" TextAlignment="Center" Margin="20,50" Visibility="Collapsed" Foreground="Gray" TextWrapping="Wrap"/>
                            
                            <!-- Tomorrow's schedule list -->
                            <ListView x:Name="TomorrowScheduleListView" Margin="0" SelectionMode="Single" IsItemClickEnabled="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="15,10" Margin="0" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Vertical">
                                                <!-- Green badge hidden for tomorrow -->
                                                <Border Background="Green" CornerRadius="4" Padding="7,3" Margin="0,0,0,15" HorizontalAlignment="Left" 
                                                        Visibility="Collapsed">
                                                    <TextBlock FontSize="14" Foreground="White" HorizontalAlignment="Center">
                                                        <Run Text="{Binding time_until_departure_prefix}"/>
                                                        <Run Text="{Binding time_until_departure_value}"/>
                                                    </TextBlock>
                                                </Border>
                                                
                                                <!-- Main grid with three columns -->
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <!-- Row for times -->
                                                        <RowDefinition Height="Auto"/>
                                                        <!-- Row for paths -->
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- Left column: Departure time -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding departure_time}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    
                                                    <!-- Center column: Travel duration with longer gray bars -->
                                                    <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Left gray bar (1.5x longer) -->
                                                        <Rectangle Grid.Column="0" Fill="LightGray" Width="75" Height="1" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        
                                                        <!-- Centered travel duration -->
                                                        <TextBlock Grid.Column="1" Text="{Binding travel_duration}" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        
                                                        <!-- Right gray bar (1.5x longer) -->
                                                        <Rectangle Grid.Column="2" Fill="LightGray" Width="75" Height="1" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                    </Grid>
                                                    
                                                    <!-- Right column: Arrival time -->
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding arrival_time}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    
                                                    <!-- Left column: Departure path -->
                                                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="16" Foreground="Gray" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Run Text="Путь "/>
                                                        <Run Text="{Binding path}"/>
                                                    </TextBlock>
                                                    
                                                    <!-- Right column: Arrival path -->
                                                    <TextBlock Grid.Row="1" Grid.Column="2" FontSize="16" Foreground="Gray" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <Run Text="Путь "/>
                                                        <Run Text="{Binding path}"/>
                                                    </TextBlock>
                                                </Grid>
                                                
                                                <!-- Train type with color coding -->
                                                <TextBlock Text="{Binding train_type}" FontSize="14" Foreground="{Binding train_type_color}" HorizontalAlignment="Left" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding train_route}" FontSize="16" Foreground="Gray" HorizontalAlignment="Left" Margin="0,2,0,5" TextWrapping="Wrap" Visibility="{Binding train_route_visibility}"/>
                                                
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Loading indicator (white color) -->
                    <ProgressRing x:Name="TomorrowLoadingProgressRing" Grid.Row="0" Width="50" Height="50" IsActive="False" 
                                  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0"/>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>