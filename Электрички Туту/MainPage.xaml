<Page
    x:Class="Электрички_Туту.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Электрички_Туту"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Tapped="Page_Tapped">
    
    <Page.BottomAppBar>
        <CommandBar>
            <!--<AppBarButton Icon="Help" Label="Инфо" Click="InfoButton_Click"/>-->
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="AboutButton" Icon="Help" Label="Информация" Click="InfoButton_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>

    </Page.BottomAppBar>

    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Top">
            <TextBlock Text="Расписание электричек" FontSize="24" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <!-- From station section -->
            <TextBlock Text="Откуда:" Margin="0,0,0,5"/>
            <TextBox x:Name="FromTextBox" PlaceholderText="Введите станцию отправления" TextChanged="FromTextBox_TextChanged" Margin="0,0,0,0"/>
            
            <!-- From suggestions -->
            <Border BorderBrush="Black" BorderThickness="1" Background="White" Visibility="Collapsed" x:Name="FromSuggestionsBorder" Margin="0,0,0,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200">
                    <ListBox x:Name="FromSuggestionsList" SelectionChanged="FromSuggestionsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="24" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="Padding" Value="15,12" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- To station section -->
            <TextBlock Text="Куда:" Margin="0,0,0,5"/>
            <TextBox x:Name="ToTextBox" PlaceholderText="Введите станцию назначения" TextChanged="ToTextBox_TextChanged" Margin="0,0,0,0"/>
            
            <!-- To suggestions -->
            <Border BorderBrush="Black" BorderThickness="1" Background="White" Visibility="Collapsed" x:Name="ToSuggestionsBorder" Margin="0,0,0,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200">
                    <ListBox x:Name="ToSuggestionsList" SelectionChanged="ToSuggestionsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="24" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="Padding" Value="15,12" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <Button x:Name="ViewScheduleButton" Content="Показать расписание" Margin="0,20,0,0" Click="ViewScheduleButton_Click" HorizontalAlignment="Stretch"/>

            <!-- History section -->
            <TextBlock Text="История поиска:" Margin="0,30,0,10" FontSize="18" FontWeight="SemiBold"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200">
                <StackPanel x:Name="HistoryPanel" />
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>